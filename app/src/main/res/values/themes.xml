<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AndroidFocusMode" parent="android:Theme.Material3.Light">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue_dark</item>
        <item name="android:colorPrimary">@color/primary_blue</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary_blue</item>
        <item name="colorSecondaryVariant">@color/secondary_blue_dark</item>
        <item name="android:colorSecondary">@color/secondary_blue</item>
        
        <!-- Tertiary color -->
        <item name="colorTertiary">@color/tertiary_blue</item>
        
        <!-- Status bar and other system colors -->
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:navigationBarColor">@color/surface_light</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Window -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.AndroidFocusMode.Dark" parent="android:Theme.Material3.Dark">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue_dark</item>
        <item name="android:colorPrimary">@color/primary_blue</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary_blue</item>
        <item name="colorSecondaryVariant">@color/secondary_blue_dark</item>
        <item name="android:colorSecondary">@color/secondary_blue</item>
        
        <!-- Tertiary color -->
        <item name="colorTertiary">@color/tertiary_blue</item>
        
        <!-- Status bar and other system colors -->
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_light</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Window -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>